@Article{Roman-Maestre2001,
  author        = {Roman Maestre, Begona},
  date          = {2001},
  title         = {Cap a una etica de la responsabilitat: de Kant a Apel},
  number        = {1},
  pages         = {19-42},
  volume        = {3},
  abstract      = {The purpose of the article is to offer an approximation to
the philosophical discussion around the concept of
responsibility. The work is divided into two well
differentiated parts. In the first part the author explains
the reason for the importance of this concept in
contemporary ethics and gives a definition, a typology, and
deals with a series of questions which arise around the
theme of responsibility. In the second part, the article
briefly analyzes the notion of responsibility formulated by
Kant, Jonas and Apel, who are, according to the author, the
main scholars on the issue of responsibility. (edited)},
