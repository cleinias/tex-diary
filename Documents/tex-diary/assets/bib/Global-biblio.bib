@Article{Drilo2003,
  author        = {Drilo, Kazimir},
  date          = {2003},
  title         = {Selbsterfahrung und Wirklichkeitserkenntnis bei Jonas und Hegel},
  number        = {1-2},
  pages         = {103-113},
  volume        = {18},
  abstract      = {What is at issue here is the correlation between
self-experience (the inner perspective) and the
understanding of reality, which is pondered upon through
the example of the fundamental characteristic of life--the
exchange of substance. As an alternative to Jonas's
phenomenological way of approaching the issue at hand, the
author provides an outline of the speculative principle of
Hegel's encyclopaedic philosophy of nature. The latter
principle is more powerful than Jonas's, inasmuch as it
points to the path, with which it is possible to avoid the
dualism between the practical and theoretical viewpoints on
