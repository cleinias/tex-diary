@Article{Rodriguez1999,
  author        = {Rodriguez, Aman Rosales},
  date          = {1999},
  title         = {Hans Jonas y el determinismo tecnologico},
  abstract      = {Hans Jonas is widely known for his ethical proposals
regarding science and technology. Less known and yet of
decisive importance for his theory of responsibility are
his opinions concerning the autonomy of modern technology.
