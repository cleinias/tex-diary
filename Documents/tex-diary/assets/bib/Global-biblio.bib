@Article{Kauffman2003Molecular-autonomous,
  author        = {Kauffman, S.},
  date          = {2003},
  title         = {Molecular autonomous agents},
  number        = {1807},
  pages         = {1089-1099},
  volume        = {361},
  abstract      = {I consider an autonomous agent to be a physical system
able to act on its own behalf, such as a bacterium swimming
up a glucose gradient. I tentatively define an autonomous
agent to be a system capable of self-reproduction and at
