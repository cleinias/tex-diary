@Article{Dechambre1948,
  author    = {DECHAMBRE, E. D.},
  date      = {1948},
  title     = {L’evolution des primates et la theorie de la foetalisation},
  doi       = {10.1515/mamm.1948.12.1.27},
  pages     = {27--41},
  volume    = {12},
  abstract  = {According to Bolk's "fetalization" theory of the origin of
man, fetal primate conditions are retained in man but have
continued their evolution in other primates. The author
reviews Bolk's arguments, adding supporting data of his
own. Special attention is given to the intellectual
development of man. The period of childhood is said to be
remarkably longer in man than in the apes. But puberty
marks the end of the creation of new centers of nerve
coordination. Thus the obstacle to continued intellectual
development is the change that takes place at puberty; and
the development of man, especially of the human brain, may
be attributed to a prolongation of the pre-sexual period
(Devaux). It is suggested that there is an antagonism
between the activities of the brain and those of the
genital organs. The infantilism resulting from this
temporary suppression of sexual activity is to be
distinguished from the degraded infantilism resulting from
castration. Prolongation of childhood, in turn, favors the
formation of stable family groups. || ABSTRACT AUTHORS: D.
D. Davis},
  ft        = {L'evolution des primates et la theorie de la foetalisation},
