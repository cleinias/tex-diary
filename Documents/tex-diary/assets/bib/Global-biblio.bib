@Article{Spinelli2001,
  author        = {Spinelli, Emidio},
  date          = {2001},
  title         = {Hans Jonas: Freedom and Determinism in the Ancient World},
  number        = {1},
  pages         = {71-84},
  volume        = {23},
  abstract      = {This short paper aims to present firstly the general
structure and the possible source of composition of the
unpublished lecture-course of Hans Jonas, entitled Problems
of Freedom. More specifically, it dwells on relevant pages
of the fourth lecture and examines in details some
key-points in support of the complicated relationship
between human free will and fatalistic determinism put
forward by Stoic philosophy. Notwithstanding Jonas's doubts
about Stoic conclusions, which tend to restrict the sphere
of human freedom to the internal domain of the self, one
can affirm that also the Stoic solution seems to impose on
us the necessity of practicing a conscious Prinzip
Verantwortung.},
  date-modified = {2006-07-13 08:53:35 -0700},
