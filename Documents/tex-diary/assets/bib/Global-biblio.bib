@Article{Harris1972,
  author        = {Harris, Errol E.},
  date          = {1972},
  title         = {Materialism and Existentialism},
  abstract      = {The materialism introduced into western thought by the
dichotomy of mind and matter resulting from the scientific
revolution of the 17th century, produced an image of the
universe as a blind, mindless machine in which man,
conscious and purposive, was an aberration. a meaningless
universe containing an aspiring spirit is an absurdity that
the mind rejects yet for which it can find no remedy. hans
jonas has discussed the issue in "the phenomenon of life";
but while he indicates a way out of the impasse in his
introduction - that the world must somehow have a character
which makes it possible for a thinking creature like man to
emerge - he never develops or elaborates this suggestion. a
revised picture of the world in the light of 20th century
science changes the relationship between man and lower
nature. modern physics (relativity and quantum theory) and
organismic biology provide a continuity of development from
physical nature to consciousness which enables us to
resolve the paradoxes both productive of and inherent in
the existentialist position. (edited).},
  date-modified = {2006-07-13 08:53:35 -0700},
  journal       = {Human Context},
  keywords      = {Jonas},
  langid        = {english},
  owner         = {stefano},
  personalnote  = {Sum 72; 4: 399 349},
  project       = {Homeostat},
  timestamp     = {2008.04.18},
}

