@Article{Domingo-Moratalla2001,
  author        = {Domingo Moratalla, Tomas},
  date          = {2001},
  title         = {El mundo en nuestras manos. La etica antropologica de Hans Jonas},
  number        = {1},
  pages         = {37-60},
  volume        = {17},
  abstract      = {La tecnologia moderna, a diferencia de la antigua,
conlleva grandes transformaciones en el mundo humano hasta
el punto de ponerlo en peligro. Por eso la etica
tradicional ya no sirve para dar respuestas a los nuevos
desafios. Solo una etica de la responsabilidad esta
capacitada para responder adecuadamente a las consecuencias
de nestra civilizacion tecnica. Esta es la contribucion
mayor de Hans Jonas. Pero esta etica no es solo un
llamamiento a la prudencia, siempre necesaria. Se trata de
una etica con un fundamento antropologico. (edited)},
