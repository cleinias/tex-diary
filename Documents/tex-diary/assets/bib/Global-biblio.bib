@Article{Schlatter2008,
  author    = {Schlatter, Mark and Ken Aizawa},
  date      = {2008},
  title     = {Walter Pitts and `A Logical Calculus'},
  doi       = {10.1007/s11229-007-9182-9},
  number    = {2},
  pages     = {235--250},
  volume    = {162},
  abstract  = {Abstract Many years after the publication of
{{\textquotedblleft}A} Logical Calculus of the Ideas
Immanent in Nervous Activity,{\textquotedblright} Warren
{McCulloch} gave Walter Pitts credit for contributing his
knowledge of modular mathematics to their joint project. In
1941 I presented my notions on the flow of information
through ranks of neurons to Rashevsky{\textquoteright}s
seminar in the Committee on Mathematical Biology of the
University of Chicago and met Walter Pitts, who then was
about seventeen years old. He was working on a mathematical
theory of learning and I was much impressed. He was
interested in problems of circularity, how to handle
regenerative nervous activity in closed {loops....For} two
years Walter and I worked on these problems whose solution
depended upon modular mathematics of which I knew nothing,
but Walter did. {(McCulloch} 1989, pp. 35{\textendash}36,
cf. {McCulloch,} 1965a, pp. 9{\textendash}10). In this
paper, we will fill in some of the details regarding
Pitts{\textquoteright}s interest in problems of
circularity, regenerative activity in closed loops of
neurons, and modular mathematics, and the way in which they
relate to {{\textquotedblleft}A} Logical
Calculus.{\textquotedblright}},
  journal   = {Synthese},
  langid    = {english},
  owner     = {stefano},
  project   = {Archaeology-of-AI},
  timestamp = {2010.04.16},
}

