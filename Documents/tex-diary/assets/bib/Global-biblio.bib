@Article{Jansohn1998,
  author        = {Jansohn, Heinz},
  date          = {1998},
  title         = {Verantwortung als Begriff der Metaphysik: Anmerkungen zur Begrundung der Ethik bei Jans Jonas},
  number        = {2},
  pages         = {419-441},
  volume        = {13},
  abstract      = {Die vorliegende Abhandlung versucht nun zum einen, dem
Gedankenweg des grossen deutsch-judischen Denkers durch
Mythos und metaphysische Argumentation auch da zu folgen,
wo Unbegehbarkeit langst erwiesen zu sein scheint. Zum
anderen gilt es aber auch, wirkliche Weglosigkeit als
solche deutlich zu machen. So z.B. wird bezweifelt, dass
das Jonassche Gottesbild und die teleologische Weltsicht
fur eine Ethikbegrundung geeignet erscheinen. Schliesslich
wird die Auffassung vertreten, dass die Jonassche
Metaphysik, die in ihrem Absolutheitsanspruch in Frage
gestellt, in ihrer kritischen Funktion aber akzeptiert
wird, als Moralbegrundung uberflussig ist. (edited)},
  date-modified = {2006-07-13 08:53:36 -0700},
