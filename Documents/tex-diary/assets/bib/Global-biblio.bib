@Article{Vogelsang2003,
  author        = {Vogelsang, Frank},
  date          = {2003},
  title         = {Das menschliche Sein als Ursprung des Sollens? Zum Ansatz einer teleologischen Ontologie bei Hans Jonas},
  number        = {1-2},
  pages         = {115-135},
  volume        = {18},
  abstract      = {Das Prinzip Verantwortung, Hans Jonas's most famous work,
emphasizes the request for the development of an ethics for
the future, which does not simply follow good conscience,
but rather discloses an objective value foundation for
human action. Jonas desires to derive ought from being with
the help of a theological ontology. An analysis of human
being represents the focus of his investigation. In doing
so, Jonas expressly opposes dualistic concepts, which have,
from the Enlightenment on, defined Western culture, in
particular under the influence of Rene Descartes's
conception. Jonas diagnoses even the predominant monistic
ideas of the natural sciences as dualism's legacy. He
opposes to this a specific understanding of man, which
places man's self-purpose in first perspective. This paper
critically analyzes Jonas's concept and inquires into his
consistence. (edited)},
  date-modified = {2006-07-13 08:53:36 -0700},
  journal       = {Synthesis Philosophica},
  keywords      = {Jonas},
  langid        = {ngerman},
  owner         = {stefano},
