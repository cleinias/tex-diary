@Article{Wolters2001,
  author        = {Wolters, Gereon},
  date          = {2001},
  title         = {Hans Jonas' Philosophical Biology},
  number        = {1},
  pages         = {85-98},
  volume        = {23},
  abstract      = {The central philosophical objective of Hans Jonas's
"philosophical biology" is to overcome the dualism of
matter and mind in a phenomenologically oriented "integral
monism". On the one hand Jonas demonstrates traces of the
mental in even the simplest biological phenomena; on the
other, he shows how central manifestations of the mental
cannot be adequately understood without their biological
foundations. Jonas's approach is at the same time both a
complement to biological science and to the standard
philosophy of biology. It is in line with contemporary
conceptions of the "embodied mind" and nonphysicalist
theories of the mental.},
  date-modified = {2006-07-13 09:02:01 -0700},
  journal       = {Graduate Faculty Philosophy Journal},
