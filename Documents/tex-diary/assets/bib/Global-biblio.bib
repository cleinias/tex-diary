@Article{Mari1999,
  author        = {Mari, Giovanni},
  date          = {1999},
  title         = {Per un nuovo senso della storia Nietzsche e Braudel},
  abstract      = {The current lack of a sense of history seems to mark the
recovery from the "historical disease" (historische
Krankheit) desired by Nietzsche's anti-Historismus (in
Unzeitgemasse Betrachtungen, II) and the recognition of
that "plastic force" (plastische Kraft) essential to
utilize history for life. Yet our existence appears to be
inexorably trapped in the present. This is due to the
belief in the sense of history as a being of history (such
as future, value, utopia, hope, progress, goal, etc.)
Braudel post-historismus, by decomposing historical unity
and defining a contingent unity of history, represents an
important contribution towards a new conception of sense of
history.},
