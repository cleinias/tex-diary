@Article{Handelman1999,
  author        = {Handelman, J. M.},
  date          = {1999},
  title         = {Culture jamming: Expanding the application of the critical research project},
  volume        = {26},
  abstract      = {Culture-jamming represents activity aimed at countering
the continuous, recombinant barrage of capitalist laden
messages fed through the mass media. This term was coined
by the Media Foundation (a not-for-profit, non-academic,
social activist organization) to describe their consumer
resistance crusade. The Media Foundation's culture-jamming
tactics adhere to the spirit and normative structure of the
critical theory paradigm. These culture-jamming activities
present an opportunity to develop a framework for
evaluating a critical research project and for
conceptualizing the application of critical theory beyond
the academic environment.},
  address       = {Provo, Utah},
