@Article{Codeluppi2004,
  author        = {Codeluppi, Vanni},
  date          = {2004},
  title         = {Produzione e consumo: prospettive per la ricerca},
  pages         = {14--30},
  volume        = {93},
  abstract      = {An economic process can be conceived of as a linear
process in which, through utilization of material \& human
resources, a good is produced & then offered for
consumption. In the past, research focused mostly on the
production process, but in recent times, it has become
clear that production & consumption are deeply correlated.
The object of this study is to demonstrate that production
& consumption must always be considered in conjunction &
that their relation depends strictly on social evolution.
Moreover, to explore new dynamics & emerging themes, it is
necessary to adopt new research paradigms, eg,
globalization, ethnic consumption, social movements,
consumption genders, & urban & suburban space & time. 95
References. M. Williamson.},
