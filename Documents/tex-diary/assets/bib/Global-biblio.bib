@InBook{Wettergren2002,
  author        = {Wettergren, Asa},
  booktitle     = {Emotions and Social Movements},
  title         = {Mobilizing through the Reality Shock Effect? Culture Jamming and Mobilization-The Case of Adbusters},
  abstract      = {How are emotions involved in the counter-cultural
mobilization of the Adbusters? Via the analysis of visual
material produced by the Adbusters the aim is to answer
this question. Founded in 1989 by ex-marketing man, Kalle
Lasn, the Media Foundation Adbusters is an organization
engaged in the practice of culture jamming. As semiotic
resistance, this practice is growing in a social context
increasingly invaded by corporate logos. The development of
Internet and cyberpolitics moreover provide culture jammers
with new discourses and a new arena for counter-hegemonic
struggle. A complex phenomenon, culture jamming is both a
technique for resistance and an emerging movement against
global corporations and consumer culture. In the Adbusters'
attempt to construct a social movement, emotions can be
seen as central. Emotions are manifest in their use of
black humor and irony and in Lasn's quest against the
'shame' of postmodernism. Irony in culture jamming is also
a way to deal with the ambiguous practice of using the
means of consumer culture to fight it. This ambiguity is
obvious in the aggressive way in which the Adbusters market
the anti-corporate message. As understanding irony presumes
shared experience and shared cultural capital, it may have
an unwanted exclusive effect. This may be the reason why
the uncommercials and the social campaigns of the Adbusters
play on emotions of shock and fear and tend to go from
irony to intimidation. It is discussed whether the effects
of the mobilizing efforts might be deterring, reinforcing
people's bonds to consumer culture instead of encouraging
resistance.},
  crossref      = {FlamKing2005},
  date-added    = {2005-10-24 11:56:34 -0700},
  date-modified = {2005-10-28 09:23:17 -0700},
  keywords      = {Culture jamming; Countercultures; Countermovements; Mobilization; Resistance; Consumerism; Emotions 0826 mass phenomena; social movements},
  langid        = {english},
