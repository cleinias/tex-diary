@Article{Margaroni2004,
  author        = {Margaroni, Maria},
  date          = {2004},
  title         = {The Time of a Gift},
  number        = {1},
  pages         = {49--62},
  volume        = {48},
  abstract      = {My contention in this essay is that, in his desire to keep
what he calls the "pure" gift without temporality, Jacques
Derrida sets up an ineffable exteriority that is (quasi-)
transcendent and without relation. My main concern is to
suggest that Emmanuel Levinas permits us to think the
"being-without" of the gift wholly otherwise. Thus, if the
gift remains "without" the circle of the proper, this is
because it 'ek-sists' no longer in an atemporal temporality
perceived as the other of time but, as Levinas puts it, "in
a time without me," i.e., in the time of the other.},
  callnumber    = {Owned},
