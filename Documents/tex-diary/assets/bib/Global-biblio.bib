@Article{Gronke2003,
  author        = {Gronke, Horst},
  date          = {2003},
  title         = {Geht nicht nach Utopia! Hans Jonas' mahnende Worte an die Fortschrittsgesellschaft und ihre Ethikkommissionen},
  number        = {1-2},
  pages         = {227-244},
  volume        = {18},
  abstract      = {The "new ethics" of Hans Jonas requires that the projects
jeopardizing the moral status of man or the future of
mankind be abandoned--even if they were to alleviate the
suffering of an individual, and even if they had to
restrict the wish for the betterment of the living
standard. Jonas's arguments are presented and evaluated
through the example of the brain death discussion. The
intuitional-ontological foundation of his ethics of
responsibility is reconstructed with the help of Husserl's
concept of epoche. Finally, it is shown that, once the
ethics of responsibility is oriented towards the regulative
idea of consensus, criticism of utopia can be integrated
with the requirement for the ethical development of
society. (edited)},
