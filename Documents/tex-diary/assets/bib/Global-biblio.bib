@InBook{Pawliszyn2002,
  author        = {Pawliszyn, Aleksandra},
  booktitle     = {Analecta Husserliana: The Yearbook of Phenomenological Research Vol,},
  date          = {2002},
  title         = {A Temporality of Dasein (Heidegger) and a Time of the Other (Levinas)},
  editor        = {Tymieniecka, Anna Teresa},
  pages         = {193--204},
  publisher     = {Kluwer},
  volume        = {LXXVII},
  abstract      = {My intention is to discuss the basic movements of
Heidegger's and Levinas's philosophy that are essential to
describe the sense of a human being. Both philosophers are
seen as successors to Husserl's phenomenology, however,
they come to the conclusions in an interesting manner that
is, at first glance, quite different. Because for Heidegger
Dasein is a spring of time, it does not have the same
meaning as loneliness of being (a man) according to
Levinas. Both philosophers have recognized a phenomenon of
death in a different way: according to Levinas death is a
mysterious passiveness caused by suffering, and according
to Heidegger it is the main impulse to provoke existence to
its highest consciousness. One could argue that these two
philosophies are complementary: if living in an appropriate
way Dasein one will reconsider his attitude toward other
people, and a man existing in a face to face relation will
reconsider his attitude toward himself. (edited)},
  address       = {Dordrecht},
  callnumber    = {ST: Green B3279 .H94 A13 V.77},
  date-modified = {2005-11-29 10:33:07 -0800},
  keywords      = {Dasein ; Temporality Heidegger ; Levinas, E},
  langid        = {english},
  personalnote  = {English Contribution},
  project       = {Passivity},
  timestamp     = {2007.01.09},
  toread        = {Yes},
}

