@Book{Vuillemin1996,
  author        = {Vuillemin, Jules},
  date          = {1996},
  title         = {Necessity or Contingency: The Master Argument},
  isbn          = {1881526852},
  publisher     = {CSLI},
  abstract      = {From these premises having to do with necessity and
contingency, the Master Argument derived a contradiction
which imperiled freedom. A text of Aristotle helps to
reconstruct the argument in historical terms, to show its
soundness and to understand its architectonic power for
opening clear perspectives in ancient but also in modern
philosophy. The original meaning of these premises belong
to a special branch of modal temporal logic (with temporal
indexing of modalities and of sentences). In other words,
the difficulties concerning the conditions that make
freedom possible are dependent on physics rather than on
logic. This is true for the Stoics and the Epicureans as
well as for John Duns Scotus and Kant. An epilogue explores
the consequences of this state of affairs by outlining the
Master Argument in terms of present physics.},
  address       = {Stanford, Calif.},
  callnumber    = {Owned},
  date-added    = {2007-01-10 17:55:45 -0600},
