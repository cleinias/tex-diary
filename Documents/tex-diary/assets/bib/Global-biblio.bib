@Article{Kurreck2003,
  author        = {Kurreck, Jens},
  date          = {2003},
  title         = {Zwischen Technikoptimismus und Kassandrismus: Grundriss fur eine aktuelle Kasuistik der Gen- und Biotechnologie auf der Basis der Verantwortungsethik von Hans Jonas},
  number        = {1-2},
  pages         = {245-272},
  volume        = {18},
  abstract      = {This paper investigates the importance that the arguments
set forth by Jonas have in current discussions, and whether
the principle of responsibility is sufficient for an
evaluation of all the ethically relevant issues of modern
bioscience. Three topics are exemplarily discussed: the
dangers of genetic technology, the cloning of man, and
genetic diagnostics. It follows that the first two fields,
due to their far-reaching consequences, are typical fields
of the application of Jonas's ethics of responsibility for
the future. Besides the technical difficulties, the
decisive existential argument against the reproductive
cloning of man is, first and foremost, the asynchrony of
the clone and his/her cell donor. However, a thorough
consideration of the problem is necessary regarding further
technical development, since besides reproductive,
therapeutic cloning must also be assessed. (edited)},
  date-modified = {2006-07-13 08:53:36 -0700},
  journal       = {Synthesis Philosophica},
  keywords      = {Jonas},
  langid        = {ngerman},
  owner         = {stefano},
