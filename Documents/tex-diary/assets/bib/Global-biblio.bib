@Article{CUENOT1942,
  author    = {Cuenot, L.},
  date      = {1942},
  title     = {Man's place in nature},
  number    = {(9)},
  pages     = {395--401},
  volume    = {80},
  abstract  = {General considerations about man's place in the universe.
The author attributes the success of the genus Homo to 3
factors; (1) man develops slowly and is genitally
behindhand; this had as consequences, the necessary
formation of family, then of clan, the creation of
language, and the possibility of a long education; 2) man
has a very large conceptual intelligence; this has allowed
him to invent tools and engines with continual
improvements, and to solve by abstraction and by thought,
the most varied problems; 3) man has a great adaptability
and is not fastidious as regards food and habitat; this has
allowed him to spread over nearly the entire surface of the
earth, principally colonizing the temperate regions, where
agriculture and breeding are easy, where fruits and fodder
are abundant, and where wild beasts and parasites are least
numerous. The author describes some changes in the human
body since the time of Pithecanthropus, and considers that
future transformations will be very slight. Bolk's
fetalization-theory regarding the origin of man, is
summarized. || ABSTRACT AUTHORS: J. J. Symoens},
