@Article{Code1976,
  author        = {Alan Code},
  date          = {1976},
  title         = {The Persistence of Aristotelian Matter},
  pages         = {357--367},
  volume        = {29},
  abstract      = {JONES ("PHILOSOPHICAL REVIEW", VOLUME LXXXIII) ARGUES THAT
FOR ARISTOTLE THE MATTER INVOLVED IN A SUBSTANTIAL CHANGE
IS SIMPLY THAT WHICH (I) EXISTED PRIOR TO THE PRODUCT, (II)
BECAME THAT PRODUCT, AND (III) BY BECOMING THAT PRODUCT
CEASED TO EXIST. WE PROVIDE AN EXEGESIS OF ARISTOTLE'S
DISCUSSION OF THE ELEMENTS OF CHANGE ("PHYSICS", A7), AND
SHOW THAT WHEREAS THE LACK SATISFIES ALL THREE CONDITIONS
THE MATTER SATISFIES ONLY THE FIRST TWO. WE ALSO SHOW THAT
OTHER PASSAGES JONES DISCUSSES (IN "METAPHYSICS, GENERATION
AND CORRUPTION") SUPPORT THE VIEW THAT MATTER IS INTRODUCED
AS A PERSISTING ELEMENT.},
