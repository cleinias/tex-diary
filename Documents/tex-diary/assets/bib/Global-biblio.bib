@Article{Morrison2005,
  author        = {Morrison, Glenn},
  date          = {2005},
  title         = {Levinas' Philosophical Origins: Husserl, Heidegger and Rosenzweig},
  number        = {1},
  pages         = {41--59},
  volume        = {46},
  abstract      = {The article explores the primary origins of Levinas's
thought. It examines the phenomenology of Edmund Husserl,
Martin Heidegger's ontological phenomenology in Being and
Time and Franz Rosenzweig's eschatological Messianism in
The Star of Redemption. Following each examination is a
discussion on the extent to which each thinker has
contributed to Levinas's philosophical development.
Together, the fundamental projects of Husserl and Heidegger
have provided much of the phenomenological language for
Levinas's ethical metaphysics or 'post-phenomenology'.
However, it is the work of Franz Rosenzweig that has given
Levinas an ethical opening to think beyond the Heideggerian
notions of Being, authenticity and temporality.},
  date-modified = {2005-11-28 21:38:31 -0800},
  journal       = {Heythrop Journal},
  keywords      = {Metaphysics ; Ontology ; Phenomenology Heidegger ; Husserl ; Levinas, E; Rosenzweig, F},
