@Article{Joisten2003,
  author        = {Joisten, Karen},
  date          = {2003},
  title         = {Die Verantwortung der Eltern und des Staatsmannes in Hans Jonas' `Zukunftsethik':Oder: Der Philosoph auf dem Weg zwischen Sinn und Faktum zu einer Verantwortung des Menschen},
  number        = {1-2},
  pages         = {173-186},
  volume        = {18},
  abstract      = {The paper attempts to provide an anthropo-ontological
foundation of responsibility, from which it is evident that
a philosopher has the possibility to ideally-typically
fulfil this responsibility. Based on this, the paradigms of
the responsibility of statesmen and that of parents can be
described as "two wings", which find their integral centre
in a philosopher. The way in which a philosopher exists on
this path is a stumbling story. In it, he, mediating
between meaning and fact, narrates about the being and
needs of man, while understanding the uncertainty of each
"final certainty" in the topical space of the probable.
(edited)},
