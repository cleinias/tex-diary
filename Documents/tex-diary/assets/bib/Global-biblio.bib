@Article{Suzuki2005b,
  author    = {Suzuki, Mototaka and Floreano, Dario and {Di Paolo}, Ezequiel A.},
  date      = {2005},
  title     = {The contribution of active body movement to visual development in evolutionary robots},
  doi       = {10.1016/j.neunet.2005.06.043},
  issn      = {0893-6080},
  number    = {5},
  pages     = {656--665},
  volume    = {18},
  abstract  = {Inspired by the pioneering work by Held and Hein (1963) on
the development of kitten visuo-motor systems, we explore
the role of active body movement in the developmental
process of the visual system by using robots. The receptive
fields in an evolved mobile robot are developed during
active or passive movement with a Hebbian learning rule. In
accordance to experimental observations in kittens, we show
that the receptive fields and behavior of the robot
developed under active condition significantly differ from
