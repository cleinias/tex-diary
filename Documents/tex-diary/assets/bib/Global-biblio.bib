@Article{Mijsberg1928,
  author    = {Mijsberg, W. A.},
  date      = {1928},
  title     = {The ancestry of man},
  pages     = {87--103},
  volume    = {1928},
  abstract  = {Comparison of a feature displayed by man with a
corresponding feature in other primates raises in each case
the question whether man has retained more primitive
conditions, or has deviated further from the common
ancestral type. The facts discovered by comparative
anatomical research often fail to answer this question, as
the comparative anatomist often can not tell primitive
conditions from specializations. The facts from
palae-ontologic research must also be accepted with great
care, as really ancestral types are discovered only by mere
chance. The extinct human types which are known are
specialized contemporaries of our real ancestors, which
must have been non-specialized; accordingly, we do not know
whether or not the extinct human types which have been
discovered resembled our ancestors more than we do. The
results of comparative ontogenetic research are more
reliable, but strict adherence to the biogenetic law would
be a source of grave mistakes, since, according to this
rule, changes in the ontogenetic development should occur
at its end only; moreover these changes should always
consist of additions to the ancestral ontogenesis. Bolk, in
many papers on his "Fetalisation-theory," has pointed out
that in the last stages of human evolution, the terminal
changes in the ontogenetic development consist of
suppression of the later stages of the development of man's
immediate forerunners. In investigations on the development
of the vertebral spines in vertebrates the author was led
to conclude that evolution may be brought about by changes
occurring in the course of ontogenetic development, which
changes he termed "intercurrent changes." The process
itself he has called "Diametagenesis." At first,
intercurrent changes do not alter the end result of the
ontogenetic development; but later on, in more remote
offspring, the later stages of ontogenetic development also
bear the stamp of the diametagenetic changes; finally,
those changes last till in adult life. The evolution of the
high brain-weight in man is a case of diametagenesis. ||
ABSTRACT AUTHORS: W. A. Mijsberg},
  ft        = {De afstamming van den mensch},
  journal   = {1 Handelingen 5th Nederlandsch Indisch Natuurwetensch Congres Soerabaja},
  owner     = {stefano},
  tc        = {0},
  timestamp = {2019.03.24},
