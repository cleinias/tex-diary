@Article{Mancini1993,
  author        = {Mancini, Sandro},
  date          = {1993},
  title         = {Per una interpretazione fenomenologica di Jonas},
  abstract      = {L'articolo analizza il paradigma teorico del "Principio
Responsabilita", valorizzando imolti aspetti innovativi
nell' impostazione del rapporto di umano e nonumano, e
focalizzando alcuni punti deboli: anzitutto la sua
connotazione antiutopica, che nasce da una critica
fuorviante e superficiale del "Principio Speranza" di
Bloch. Ma il limite piu rilevante consiste nella
presupposizione dogmatica di una continuita tra scienza e
filosofia, entrambe concepite Aristotelicamente in funzione
della ricerca delle strutture oggettive dell 'essere.
Occorre quindi separare il nucleo originale del "Principio
Responsabilita" dalla sua cornice Aristotelica e
oggettivistica, sviluppandolo in una biu feconda
prospettiva fenomenologica e dialettica.},
