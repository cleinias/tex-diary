@Article{Bennett2003,
  author        = {Bennett, W. Lance},
  date          = {2003},
  title         = {Communicating Global Activism: Strengths and Vulnerabilities of Networked Politics},
  number        = {2},
  pages         = {143--168},
  volume        = {6},
  abstract      = {Many observers doubt the capacity of digital media to
change the political game. The rise of a transnational
activism that is aimed beyond states \& directly at
corporations, trade, \& development regimes offers a
fruitful area for understanding how communication practices
can help create a new politics. The Internet is implicated
in the new global activism far beyond merely reducing the
costs of communication, or transcending the geographical &
temporal barriers associated with other communication
media. Various uses of the Internet \& digital media
facilitate the loosely structured networks, the weak
identity ties, \& the patterns of issue \& demonstration
organizing that define a new global protest politics.
Analysis of various cases shows how digital network
configurations can facilitate: permanent campaigns; the
growth of broad networks despite relatively weak social
identity \& ideology ties; transformation of individual
member organizations \& whole networks; \& the capacity to
communicate messages from desktops to TV screens. The same
qualities that make these communication-based politics
durable also make them vulnerable to problems of control,
decision making, \& collective identity. 42 References.
Adapted from the source document.},
  date-added    = {2005-10-24 11:56:34 -0700},
  date-modified = {2005-10-28 09:24:43 -0700},
  journal       = {Information, Communication \& Society},
  keywords      = {Culture jamming; Globalization; Activism; Protest Movements; Internet; Social; Networks; Communication},
  langid        = {english},
