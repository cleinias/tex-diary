@Article{Chanter1997,
  author        = {Chanter, Tina},
  date          = {1997},
  title         = {Traumatic Response: Levinas's Legacy},
  number        = {Supplement},
  pages         = {19--27},
  volume        = {41},
  abstract      = {In a 1975/76 lecture course Levinas refines his earlier
critique of Heidegger's notion of death. Levinas thinks of
death as the "time of patience." Heidegger's notion of
being-towards-death had required us to rethink temporality
by starting with Dasein's finitude, but for Levinas, death
must be understood on the basis of time. It is not through
death that there is time, but through the time of patience,
endurance, or passivity that there is death, I suggest that
it is Levinas's notion of trauma that puts into question
the Heideggerian priority of Dasein's death and the
structure of belonging that facilitates it.},
  callnumber    = {Owned},
  date-modified = {2005-11-29 12:55:11 -0800},
  journal       = {Philosophy Today},
  keywords      = {God ; Metaphysics ; Ontology ; Theology; Levinas Levinas, E},
  langid        = {english},
  local-url     = {file://localhost/Users/stefano/Documents/Texts-papers-and-books/Husserl,%20Gadamer%20and%20Heidegger/Levinas/Chanter1997.pdf},
  personalnote  = {0031 8256},
  project       = {Passivity},
  read          = {Yes},
  timestamp     = {2007.01.09},
}

@Article{Chanter1998,
  author        = {Chanter, Tina},
  date          = {1998},
  title         = {The Temporality of Saying: Politics beyond the Ontological Difference},
  number        = {1/2},
  pages         = {503--528},
  volume        = {20/21},
  abstract      = {I locate three vantage points of Levinas's engagement with
Heidegger's philosophy of time. Spanning the trajectory of
Levinas's life work, these strategic markers provide a
sense of the changing character of Levinas's negotiations
not only with Heidegger's oeuvre, but also with his
politics. I trace Levinas's reaction to Heidegger from his
early enthusiasm, which is severely tempered in the
sobering experiences of the 1930s and 40s, to Levinas's
final years. In the late work Levinas extended to Heidegger
a generosity that deserted him in the middle years of his
lifelong attempt to come to terms with his own early
Heideggerianism.},
