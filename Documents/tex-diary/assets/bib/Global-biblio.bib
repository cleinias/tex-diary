@Article{Nikulin2001,
  author        = {Nikulin, Dmitri},
  date          = {2001},
  title         = {Reconsidering Responsibility: Hans Jonas' Imperative for a New Ethics},
  number        = {1},
  pages         = {99-118},
  volume        = {23},
  abstract      = {The purpose of the article is to reconstruct an ethics of
responsibility, primarily in the work of Hans Jonas. The
uniqueness of the 'conditio humana', considered to be
determined by a historically unprecedented power of
technology, suggests for a reformulation of the ethical
categorical imperative into that of responsibility, which
has to imply an understanding of nature as capable of
having purposes and an appeal to a continuation of the very
existence of moral agents. The relation of the 'old' and
the 'new' imperatives is then discussed, as well as the
shortcomings and advantages of the ethics of responsibility
in regard to contemporary ethical problems.},
  date-modified = {2006-07-13 08:53:35 -0700},
