@Article{Becchi2001,
  author        = {Becchi, Paolo},
  date          = {2001},
  title         = {Hans Jonas in Italien. Eine Rezeption mit Hindernissen},
  number        = {4},
  pages         = {602-618},
  volume        = {55},
  abstract      = {This article tries to reconstruct the reception of Hans
Jonas in Italy; this started mainly when the translation of
his most important work, The Imperative of Responsibility,
was published in 1990. Of course Jonas was known before,
but more as an erudite scholar of the history of religions.
The difficulty of his reception in Italy is ascribed to the
great success encountered instead by Bloch, starting from
the end of the sixties' and later on, from the seventies',
with his Prinzip Hoffnung; and, furthermore, to the fact
that Jonas--with his very peculiar viewpoints on a
bioethical issues--could be referred neither to so-called
laic bio-ethics, of utilitarian inspiration, nor to
Catholic bio-ethics. Lately, however, the crisis of the
utopian perspective and a more open bioethical debate have
led to a renewed appreciation of Jonas's thought. All his
most important works have now been translated into Italian
and a number of Ragion Pratica review (2000, number 15) was
specifically devoted to him.},
  date-modified = {2006-07-13 08:53:36 -0700},
  journal       = {Zeitschrift fuer philosophische Forschung},
  keywords      = {Jonas},
  langid        = {ngerman},
  owner         = {stefano},
  personalnote  = {0044 3301},
  project       = {Homeostat},
  timestamp     = {2008.04.18},
}

@Article{Becchi2002,
  author        = {Becchi, Paolo},
  date          = {2002},
  title         = {Technology, Medicine, and Ethics in Hans Jonas},
  number        = {2},
  pages         = {155-182},
  volume        = {23},
  abstract      = {It is unfortunate that the essays by Hans Jonas on
practical ethics collected in Technik, Medizin und Ethik
(1985) have never been published in English in a single
volume. It is certain that these essays are widely known
within Anglo-American culture, but dispersed as they are at
the moment, no book or journal is in a position to provide
an accurate idea of the breadth of Jonas's thought. The
paper gives a general view of the subjects discussed by
Jonas (human experimentation, cloning, genetic engineering,
definition of death as "brain death", organ transplants and
euthanasia) and tries to point out in a critical way the
complicated connection of these essays with Jonas' main
work: The Imperative of Responsibility.},
  date-modified = {2006-07-13 08:53:35 -0700},
  journal       = {Graduate Faculty Philosophy Journal},
  keywords      = {Jonas},
  langid        = {english},
