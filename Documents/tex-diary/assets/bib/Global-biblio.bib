@Article{Abraham2002,
  author    = {Abraham, Tara H.},
  date      = {2002},
  title     = {(Physio)Logical Circuits: The Intellectual Origins of the McCulloch-Pitts Neural Networks},
  issn      = {00225061},
  number    = {1},
  pages     = {3--25},
  volume    = {38},
  abstract  = {This article examines the intellectual and institutional
factors that contributed to the collaboration of
neuropsychiatrist Warren McCulloch and mathematician Walter
Pitts on the logic of neural networks, which culminated in
their 1943 publication, “A Logical Calculus of the Ideas
Immanent in Nervous Activity.” Historians and scientists
alike often refer to the McCulloch–Pitts paper as a
landmark event in the history of cybernetics, and
fundamental to the development of cognitive science and
artificial intelligence. This article seeks to bring some
historical context to the McCulloch–Pitts collaboration
itself, namely, their intellectual and scientific
orientations and backgrounds, the key concepts that
contributed to their paper, and the institutional context
in which their collaboration was made. Although they were
almost a generation apart and had dissimilar scientific
