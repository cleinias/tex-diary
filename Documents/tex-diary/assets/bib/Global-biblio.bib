@Article{Juric2003,
  author        = {Juric, Hrvoje},
  date          = {2003},
  title         = {Utopie--Anti-Utopie--Post-Utopie--Utopie: Zu Jonas' Kritik des marxistischen Utopismus},
  number        = {1-2},
  pages         = {207-225},
  volume        = {18},
  abstract      = {Led by the thread of "the end of utopia" and "the
postutopian era", the article sets forth with a "diagnosis
of time". Following this diagnosis and taking a set back,
the author attempts to acquire a historical-conceptual
definition of "utopia", one that would be adequate as to
modern utopian thinking so to its criticism too. The
central section of the article discloses the key points of
Jonas's criticism of "Marxist utopianism", which Jonas
expounded within the framework of his project of an ethics
of responsibility as an antiutopian ethics for our
technological civilisation. In the end, the author
considers the scope of Jonas's criticism of Marxist
utopianism and utopianism in general, particularly in the
light of the present situation, i.e., approximately twenty
years from the time that Jonas wrote his Das Prinzip
Verantwortung.},
  date-modified = {2006-07-13 08:53:36 -0700},
  journal       = {Synthesis Philosophica},
  keywords      = {Jonas},
  langid        = {ngerman},
  owner         = {stefano},
