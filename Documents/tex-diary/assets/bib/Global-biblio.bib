@InBook{Mensch2005,
  author        = {Mensch, James R.},
  booktitle     = {Between Description and Interpretation, The Hermeneutic Turn in Phenomenology, Wiercinski, Andrzej},
  date          = {2005},
  title         = {The Ethical Limits to Self-Making},
  pages         = {558-570},
  publisher     = {The Hermeneutic Pressess},
  abstract      = {Examining the theme of self-making as developed in
Heidegger and Levinas, I argue that in both cases
self-making is unlimited. Because of this, the process of
such self-making involves unlimited obligations -- either
to our own being (as in Heidegger) or to the being of the
other (as in Levinas). Relying on Hans Jonas's description
of life as inherently future-directed, I claim that what is
not taken into account by either Heidegger or Levinas is
the role of our flesh in the projects through which we make
ourselves. A reflection on such flesh discloses the limits
of our self-making and the obligations it imposes.},
  address       = {Toronto},
  date-modified = {2006-07-13 08:53:36 -0700},
  keywords      = {Jonas},
