@Article{Brune2003,
  author        = {Brune, Jens Peter},
  date          = {2003},
  title         = {Verstehen des Lebendigen? Die Aktualitat der Philosophie des Organischen von Hans Jonas},
  number        = {1-2},
  pages         = {83-102},
  volume        = {18},
  abstract      = {Jonas has noticed an ontological "break between man and
being" in Cartesian dualism, a break that, in the
spiritual-historical respect, has continued in the form of
an alternative, on the one hand, of the monistic idealism
of the philosophy of consciousness oriented towards
"isolated selfhood", and on the other, of the
all-objectifying monistic materialism. From the ontological
perspective, each of these two monisms should represent a
totality on its own, and should thus exclude the other in
advance. Yet, the modern spirit, according to Jonas, still
hesitates between these two perspectives--if, however,
monistic materialism prevails, then it would "eliminate the
idea of man as man." (edited)},
  date-modified = {2006-07-13 08:53:36 -0700},
  journal       = {Synthesis Philosophica},
