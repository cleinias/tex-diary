@InBook{Roskies2022,
  author    = {Roskies, Adina L.},
  booktitle = {The Oxford Handbook of Moral Psychology},
  title     = {The Limits of Neuroscience for Ethics},
  doi       = {10.1093/oxfordhb/9780198871712.013.26},
  editor    = {Manuel Vargas and John L. Doris},
  eprint    = {https://academic.oup.com/book/0/chapter/351587270/chapter-ag-pdf/55486763/book\_41278\_section\_351587270.ag.pdf},
  pages     = {495--508},
  publisher = {Oxford University Press},
  abstract  = {Ethics is concerned with the normative or prescriptive,
and science with the descriptive. These differences are
illustrative of the famous gap between ‘ought’ and
‘is’. Given these differences in scope and subject
matter, one might wonder what, if anything, science may
have to offer ethics. Here I focus on the brain sciences,
and looking at several case studies in both normative
ethics and metaethics, I argue that the gap between the
normative and descriptive is unbridgeable, but that despite
this, neuroscience has much to contribute to ethical
thought. The way in which it most clearly contributes is by
providing descriptive premises to normative arguments.},
  address   = {Oxford, UK},
  langid    = {english},
  year      = {2022},
}

