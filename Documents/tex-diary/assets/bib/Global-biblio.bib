@Article{Durie1999,
  author        = {Durie, Robin},
  date          = {1999},
  title         = {Speaking of Time...Husserl and Levinas on the Saying of Time},
  number        = {1},
  pages         = {35--58},
  volume        = {30},
  abstract      = {Husserl's investigations into the absolute flux of time
constituting consciousness notoriously conclude with the
admission that 'For all of this, names are lacking'. Rather
than phenomenology lacking names, Levinas questions whether
'the thing itself is beyond the nameable'. This paper
demonstrates how the constitution of the flow is founded in
a double movement of 'de -presentation'
(Ent-Gegenwartigung) and lapse. Having shown why Levinas
argues that this movement is sensibly lived through prior
to being constituted within intentionality, the paper
concludes by explaining how an 'ethical saying', in
Levinas's terms, is necessary if the sensing of time's
constitution is to be articulated. (edited)},
