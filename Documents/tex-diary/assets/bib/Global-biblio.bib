@Article{Dorter1978,
  author        = {Dorter, Kenneth},
  date          = {1978},
  title         = {Ontology and Contingency},
  pages         = {93-114},
  volume        = {8},
  abstract      = {If reality appeared to us just as it is in itself there
would be no need of metaphysics but only empirical
observation. why then is it believed that appearance and
reality differ? in the present study it is argued that
ultimately it is the notion of contingency (irrational
causation) that differentiates the two. this is explored in
terms of certain representative philosophers as well as an
examination of the concept of contingency itself, and it is
seen how various philosophical positions turn on the way
contingency is conceived.},
  date-added    = {2007-01-10 17:55:45 -0600},
