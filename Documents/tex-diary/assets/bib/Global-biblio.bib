@Article{Hosle2001,
  author        = {Hösle, Vittorio},
  date          = {2001},
  title         = {Ontology and Ethics in Hans Jonas},
  number        = {1},
  pages         = {31-50},
  volume        = {23},
  abstract      = {The essay analyzes the connections between Jonas's
philosophy of biology and his foundation of ethics. Jonas's
phenomenology of the organic mode of being is a
generalization of Heidegger's theory of "Dasein"; at the
same time, Jonas wants to overcome the moral vacuum of
"Being and Time". The structure of the organic is regarded
as valuable, because it is able to set ends for itself.
Still, humans are far more valuable than nonrational
organisms. Jonas's (weak) anthropocentrism does not entail,
however, that humans are the source of moral value. A
comparison with transcendental foundations of ethics ends
the essay.},
