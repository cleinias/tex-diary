@Article{BosleyPanayides2003,
  author        = {Bosley, Richard and Panayides, Christos Y.},
  date          = {2003},
  title         = {Metaphysics E. 2-3 and the Accidental},
  number        = {3-4},
  volume        = {25},
  abstract      = {This paper defends a reading of Metaphysics E. 2-3 which
accounts for the accidental without running afoul of
Aristotle's general modal, causal theory. The question is
not whether the accidental has a cause; the question is
whether every active cause gives rise to its effect with
the help of a process. With a restoration of an alternative
textual reading, the question is answered in the negative.
The consequence for interpretation is a coherent reading of
both Chapters 2 and 3.},
