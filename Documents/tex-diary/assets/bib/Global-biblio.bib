@Article{Mandrioni1995,
  author        = {Mandrioni, Hector Delfor},
  date          = {1995},
  title         = {Responsabilidad y temporalidad},
  abstract      = {This article stresses the importance given today in ethics
to the theme of responsibility and explores the role played
by the three ecstasies of temporality in the appeal which
calls for an answer from responsible men. The appeal can
arise from an "immemorial" sphere which precedes and
addresses us from our origins, the present in which the
gift of epochal Being is bestowed to us and the future of
humanity which commands us to so act as to ensure its
survival. This is why the article examines three positions.
First, as regards the past, Levinas's reflection in the
framework of an ethics which enjoys primacy over ontology.
Second, with reference to the present, Heidegger's thought
in which ethical problems are absorbed within ontology.
Finally, in connection with the future, Jonas grounding of
ethics on an ontology and metaphysics of life.},
  date-modified = {2006-07-13 08:53:35 -0700},
