@Article{Neuville1927,
  author    = {NEUVILLE, H.},
  date      = {1927},
  title     = {De certains caracteres de la forme humaine et de leurs causes},
  number    = {(5/6)},
  pages     = {491--515},
  volume    = {37},
  abstract  = {This paper and a previous one discuss a theory of Bolk in
regard to the fetalization of man's form and retardation of
functions as a result of a modification in the endocrine
system. The author gives evidence against it from his work
on the hand and foot, cecum and appendix, labia majora and
mons veneris, penis and hymen. In man the thumb is to the
3rd digit as 5 is to 7 or 8 and in the monkey not more than
1 to 2. In the human fetus and in young monkeys the 2nd and
3rd meta-carpals are the same length, in the human adult
the 2nd is longer than the 3rd, and in adult monkeys the
3rd is longer. The rounded heads of 4 of the metacarpals in
man and the trochlear heads in monkeys and animals
generally are functional, as are also the variable sesamoid
bones. These and other characters of the hand are not fetal
but evolutionary and functional. The large size of the
great toe in man, the solidity, rigidity, and strength of
the foot, and the powerful arch are factors of man's erect
posture, used for stability and progression; and totally
unlike the loosely built, flexible, and unstable foot of
the other Primates although the fetal stage of all is
similar. The adult human foot is not fetal in structure.
The adult human cecum and appendix are more lemurine than
anthropoid, therefore not fetal. In man the presence of the
frenum of the penis and the small clitoris are fetal, and
the enlarged clitoris and the fibrous, cartilaginous or
bony penis of the chimpanzee, for example, are much further
advanced; but man is more advanced in the corpus
spongiosum, which is ventral and erect to the end, and in
the foreskin covering the glans, as well as in the great
mons veneris and labia majora and hymen. The secondary
sexual characters of the human [female] are very advanced
in evolution, more than in monkeys or any other mammals. In
man the penis and the rugae of the vagina are both better
developed for libido than in monkeys. This is not fetal. In
the [female] human fetus the labia majora and mons veneris
are poorly developed, in all animals present, but in adult
man they are greatly developed, whereas in monkeys and some
other mammals they have become almost obliterated in the
adult, although sometimes large in the chimpanzee and
orang. The mons veneris is characteristically a human
development, as is also the perfect hymen, the latter being
practically absent or rudimentary in other animals. The
clitoris of the human [female] may be called fetal although
sometimes extremely developed. The endocrines have not been
proved to play a part in either man or animals during their
evolution. Hyperpituitarism, as in gigantism or acromegaly,
does not resemble either the condition in Neanderthal man
or that in the Anthropoids, nor does adrenalism, as in
Addison's disease, prove that the Black and the
Yellow-Brown peoples have sluggish adrenals. The
relationship may be suggestive but it has not yet been
proven. || ABSTRACT AUTHORS: R. B. Bean},
  journal   = {[suite] Anthropologie},
  owner     = {stefano},
  tc        = {0},
  timestamp = {2019.03.24},
  ut        = {BCI:BCI19290300003273},
  z8        = {0},
  z9        = {0},
  zb        = {0},
  zr        = {0},
  zs        = {0},
}

@Article{Newell1956,
  author    = {Allen Newell and Herbert A. Simon},
  date      = {1956},
  title     = {The Logic Theory Machine---a Complex Information Processing System},
  doi       = {10.1109/TIT.1956.1056797},
  issn      = {0096-1000},
  number    = {3},
  pages     = {61--79},
  volume    = {2},
  abstract  = {In this paper we describe a complex information processing
system, which we call the logic theory machine, that is
capable of discovering proofs for theorems in symbolic
logic. This system, in contrast to the systematic
algorithms that are ordinarily employed in computation,
relies heavily on heuristic methods similar to those that
have been observed in . human problem solving activity. The
specification is written in a formal language, of the
nature of a pseudo-code, that is suitable for coding for
digital computers. However, the present paper is concerned
exclusively with specification of the system, and not with
its realization in a computer. The logic theory machine is
part of a program of research to understand complex
information processing systems by specifying and
synthesizing a substantial variety of such systems for
empirical study.},
  journal   = {IRE Transactions on Information Theory},
  keywords  = {Artificial intelligence, Logic},
  langid    = {english},
