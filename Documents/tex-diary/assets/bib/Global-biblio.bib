@Article{Bohler2003,
  author        = {Bohler, Dietrich and Gronke, Horst},
  date          = {2003},
  title         = {In dubio pro responsabilitate: Die Orientierungskraft des Verantwortungsprinzips im okologischen und bioethischen Diskur},
  number        = {1-2},
  pages         = {137-152},
  volume        = {18},
  abstract      = {Hans Jonas has attempted to find concrete orientations for
action through having considered two thought experiments,
which are: the heuristics of fear and betting with risk.
Having done so, he has widened his phenomenological and
ontological perspective of the principle of responsibility.
It now becomes clear that the ideas of human dignity and
the principle of openness represent an important pillar of
Jonas's ethics. This links the latter to the
transcendental-pragmatic ethics of discourse, which can,
together with the principle of the discourse itself, point
towards the fundament of an ethics of coresponsibility as
an ethics of one's own responsibility in discourse with
others. The examples of bioethics and medical ethics
demonstrate that "the principle of coresponsibility' is
fruitful. (edited)},
  date-modified = {2006-07-13 08:53:36 -0700},
  journal       = {Synthesis Philosophica},
  keywords      = {Jonas},
