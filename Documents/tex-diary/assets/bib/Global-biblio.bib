@Article{Hadorn2000,
  author        = {Hadorn, Gertrude Hirsch},
  date          = {2000},
  title         = {Verantwortungsbegriff und kategorischer Imperativ der Zukunftsethik von Hans Jonas},
  number        = {2},
  pages         = {218-237},
  volume        = {54},
  abstract      = {In opposition to Kantian ethics Jonas elaborates an
ethical theory about responsibility as ontological
obligation towards the future existence of mankind, which
is ignored although he raised responsibility as ethical
subject. The paper traces the roots of Jonas' ontology in
Aristotle, Plotin and Heidegger and criticizes the
theological component within his value theory. The
categorical imperative of Hans Jonas is not about justice
between generations and cannot be reconstructed within
transcendental philosophy. Jonas ignores the collective
character of human existence in his ontology and,
therefore, gets into a dilemma with the normative analysis
of moral problems in sustainable development.},
  date-modified = {2006-07-13 08:53:36 -0700},
  journal       = {Zeitschrift fuer philosophische Forschung},
