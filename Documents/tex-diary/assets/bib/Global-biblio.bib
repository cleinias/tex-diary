@Article{Dupuis2002,
  author        = {Dupuis, Michel},
  date          = {2002},
  title         = {Le fardeau et la grace de l'endurance},
  number        = {3},
  pages         = {418-436},
  volume        = {100},
  abstract      = {The question of illness and suffering involves the
entirety of the work of Jonas and not only his works on
applied ethics. As the analysis of the context of this
question shows, Jonas meets it on several fronts: there is
the history of freedom, illness and suffering, biological
history, and again the physiological history of the meaning
of suffering. The general philosophical lesson seems to be
the following: while preserving themselves from the errors
of existentialism, it is time for human beings to recover
the virtue of endurance, which is the specific lot of
finite free, suffering and mortal existence.},
