@Article{Harold2004,
  author        = {Christine Harold},
  date          = {2004},
  title         = {Pranking rhetoric: `Culture jamming' as media activism},
  number        = {3},
  pages         = {189},
  volume        = {21},
  abstract      = {This essay explores the practice of "Culture jamming" as a
strategy of rhetorical protest. Specifically, "pranksters"
deploy the tools of the mass media and marketing in order
to take advantage of the resources and venues they afford.
Through the concept of "pranking, this essay suggests that
the most promising forms of media activism may resist less
through negation and opposition than by playfully
appropriating commercial rhetoric both by folding it over
on itself and exaggerating its tropes.},
