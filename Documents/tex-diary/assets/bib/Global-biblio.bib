@Article{Frogneux2002,
  author        = {Frogneux, Nathalie},
  date          = {2002},
  title         = {Une aventure cosmotheandrique: Hans Jonas et Luigi Pareyson},
  number        = {3},
  pages         = {500-526},
  volume        = {100},
  abstract      = {By setting out the various conceptions of myth which
marked out the work of Jonas from demythologization to the
myth of a weak God and then the final abandonment of this
literary form, the author attempts to open the way for a
metaphysical option in the form of the investment of
spirit-eros-freedom in the world. A comparison with the
ontology of freedom in Luigi Pareyson, and in particular
with his myth of divine self-origination, brings to light
an ontology of freedom in Jonas. (edited)},
  date-modified = {2006-07-13 08:53:36 -0700},
