@InBook{Roberts2023,
  author    = {Roberts, Neil},
  booktitle = {Handbook of Archaeological Sciences},
  title     = {Holocene Climate Changes and Human Consequences},
  chapter   = {16},
  doi       = {https://doi.org/10.1002/9781119592112.ch16},
  eprint    = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119592112.ch16},
  isbn      = {9781119592112},
  pages     = {321--337},
  publisher = {John Wiley \& Sons, Ltd},
  url       = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119592112.ch16},
  abstract  = {Summary Human societies have developed a wide range of
strategies for coping with a variable natural environment
that can lead to episodes of drought, frost, and flood,
often linked to years of plenty and years of food scarcity.
A Holocene perspective provides valuable insights into how
human societies have coped with such climate changes in the
past, some of them gradual, others more abrupt. During the
late Pleistocene and early-to-mid Holocene, climate changes
were determined by boundary conditions – such as solar
radiation and ice cover – that were substantially
different from those of today. The time period between
~8000 and 6000 BP represented a climatic optimum in many
parts of the world. During the last few millennia, the
boundary conditions controlling global climate became
similar to those today, except for the sharp rise in
atmospheric greenhouse gas concentrations during the
industrial era.},
  keywords  = {atmospheric greenhouse gas, climate changes, early-to-mid Holocene, food scarcity, human societies, industrial era, late Pleistocene, solar radiation},
  langid    = {english},
  year      = {2023},
}

