@Article{Donnelley2001,
  author        = {Donnelley, Strachan},
  date          = {2001},
  title         = {Philosophy, Evolutionary Biology, and Ethics: Ernst Mayr and Hans Jonas},
  number        = {1},
  pages         = {147-163},
  volume        = {23},
  abstract      = {The article encompasses a comparative study of the
biologically or organically informed worldviews of the
evolutionary biologist, Ernst Mayr, and the philosopher of
organic life, Hans Jonas. It examines their respective
critiques of classical, Newtonian science; their
alternative explanations or interpretations of biological,
including human, life; and, finally, their reflections on
the advent and substantive duties of human moral
responsibility. Differences in world view and ethical
concerns are traced to the differing roles played by
Darwinian biology in the elaboration of their
thought--difference which may serve us well when in
envisioning the full complexity of our moral
responsibilities to the future of the human and natural
world.

NOTE: THIS IS THE SAME TEXT AS Donneley2002},
  date-modified = {2006-07-13 09:02:01 -0700},
