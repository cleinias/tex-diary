@Article{Smith2001,
  author    = {Smith, Henry F.},
  date      = {2001},
  title     = {Obstacles to integration: Another look at why we talk past each other.},
  issn      = {0736-9735},
  number    = {3},
  pages     = {485 - 514},
  volume    = {18},
  abstract  = {This article, written before Stephen Mitchell's death,
draws on Mitchell's (1997) Influence and Autonomy in
Psychoanalysis to illustrate some common discursive
strategies that tend to fracture analytic dialogue. Such
strategies include marginalization of the past, the use of
sharp polarities, excessively tight linkages between theory
and technique, and argument from epistemology rather than
clinical observation. The author suggests that the clinical
situation is more complex than these positions imply, that
the polarities are inherent in the work itself, and that
theoretical differences do not necessarily define the work.
He concludes with the hope that further dialogue, based on
the description of what analysts observe themselves doing
in their own clinical work, might begin to illuminate what
they hold in common and what remains beyond integration.
(PsycINFO Database Record (c) 2013 APA, all rights
reserved). (journal abstract)},
  journal   = {Psychoanalytic Psychology},
  keywords  = {psychoanalysis, Stephen Mitchell, theory, marginalization of past, Psychoanalysis, Psychoanalysts, Psychoanalytic Interpretation, Psychoanalytic Theory},
  langid    = {english},
  owner     = {stefano},
  timestamp = {2015.07.07},
}

@InBook{Smith2001a,
  author            = {Smith, Warren},
  booktitle         = {The Age of Anxiety: Conspiracy Theory and the Human Sciences},
  date              = {2001},
  title             = {Conspiracy, Corporate Culture and Criticism},
  editor            = {Jane Parish and Martin Parker},
  isbn              = {0631231684},
  pages             = {153--165},
  publisher         = {Blackwell Publishing},
  abstract          = {Explores the relationship between contemporary corporate
culture & recent attempts to criticize its increasing
growth & influence. Naomi Klein's critique of corporate
culture, No Logo (2000), is drawn on to shed light on how
cultural corporatism creates a third culture comprising
brand names, brand people, & brand-made media. It is argued
that capitalist institutions have always been a major site
for conspiracy theory, & consumers become part of corporate
conspiracy practices by consuming mass-produced objects.
Popular forms of conspiracy theory & their links with
societal trends are examined to illustrate how they relate
to critical engagements with corporate culture & its
products. A discussion of how global corporate culture
manages to subsume "subvertising" that attempts to
undermine the corporate message maintains that even the
efforts of "culture jammers" are being incorporated into
marketing campaigns, as exemplified by Nike's "I am not/A
target market/I am an athlete" campaign. It is contended
that contemporary critiques of corporate influence as a
form of colonization run into difficulties because they
require remembering a time before the occupation. 23
References. J. Lindroth.},
