@Article{Hagemann2003,
  author       = {Dirk Hagemann and Shari R. Waldstein and Julian F. Thayer},
  date         = {2003},
  title        = {Central and autonomic nervous system integration in emotion},
  issn         = {0278-2626},
  number       = {1},
  pages        = {79 - 87},
  volume       = {52},
  abstract     = {Emotions involve physiological responses that are
regulated by the brain. The present paper reviews the
empirical literature on central nervous system (CNS) and
autonomic nervous system (ANS) concomitants of emotional
states, with a focus on studies that simultaneously
assessed \{CNS\} and \{ANS\} activity. The reviewed data
support two primary conclusions: (1) numerous cortical and
subcortical regions show co-occurring activity with \{ANS\}
responses in emotion, and (2) there may be reversed
asymmetries on cortical and subcortical levels with respect
to CNS/ANS interrelations. These observations are
interpreted in terms of a model of neurovisceral
integration in emotion, and directions for future research
are presented.},
  journal      = {Brain and Cognition},
  keywords     = {Autonomic nervous system},
  langid       = {english},
  owner        = {stefano},
  personalnote = {Affective Neuroscience},
  timestamp    = {2015.06.10},
}

