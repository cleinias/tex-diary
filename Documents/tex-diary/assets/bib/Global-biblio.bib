@Article{Ratcliffe2001,
  author        = {Ratcliffe, Matthew},
  date          = {2001},
  title         = {A Kantian Stance on the Intentional Stance},
  number        = {1},
  pages         = {29-52},
  volume        = {16},
  abstract      = {I examine the way in which Daniel Dennett (1987, 1995)
uses his 'intentional' and 'design' stances to make the
claim that intentionality is derived from design. I suggest
that Dennett is best understood as attempting to supply an
objective, nonintentional, naturalistic rationale for our
use of intentional concepts. However, I demonstrate that
his overall picture presupposes prior application of the
intentional stance in a preconditional, ineliminable,
'sense-giving' role. Construed as such, Dennett's account
is almost identical to the account of biological teleology
offered by Kant in The Critique of Judgement, with the
consequence that Dennett's naturalism is untenable.
(edited)},
  date-added    = {2006-09-26 11:59:57 -0500},
  date-modified = {2006-12-29 09:18:49 -0600},
  journal       = {Biology and Philosophy},
  keywords      = {Intention ; Kantianism ; Naturalism ; Science Dennett},
